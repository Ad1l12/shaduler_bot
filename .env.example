# -- Application --
APP_ENV=development              # development | production
APP_LOG_LEVEL=DEBUG              # DEBUG | INFO | WARNING | ERROR
APP_BASE_URL=https://your-domain.com  # Public URL (for OAuth callback)

# -- Telegram --
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_WEBHOOK_SECRET=your-random-secret-string

# -- Google OAuth --
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxx
GOOGLE_REDIRECT_URI=${APP_BASE_URL}/auth/google/callback

# -- Database --
DATABASE_URL=postgresql+asyncpg://bot:localpass@localhost:5432/calendar_bot

# -- Encryption --
ENCRYPTION_KEY=your-fernet-key   # Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"

# -- Sentry (optional) --
SENTRY_DSN=
